# ===========================================
# WALMER BACKEND - ENVIRONMENT VARIABLES
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# WOMPI (Colombia - Bancolombia)
# ===========================================
# Credenciales Sandbox proporcionadas:
WOMPI_PUBLIC_KEY=prv_test_5SNcnJrrV5wz5aP48mOypaihVS0LCXer
WOMPI_PRIVATE_KEY=prv_test_5SNcnJrrV5wz5aP48mOypaihVS0LCXer
WOMPI_EVENTS_SECRET=test_events_voAs6U5Ck7NDiSj9OKbTptw7dCUY9UH8
WOMPI_INTEGRITY_SECRET=test_integrity_QU5OBBI8N53DU4e7pIt2YYot0US4wQA2

# MODO PRODUCCIÓN (Real - Cargos a tarjetas reales)
# Para migrar a producción, reemplaza las llaves de test por las de prod
# WOMPI_PUBLIC_KEY=pub_prod_your_wompi_public_key_here
# WOMPI_PRIVATE_KEY=prv_prod_your_wompi_private_key_here
# WOMPI_EVENTS_SECRET=prod_events_your_events_secret_here
# WOMPI_INTEGRITY_SECRET=prod_integrity_your_integrity_secret_here

# MODO PRODUCCIÓN (Real - Cargos a tarjetas reales)
# Prefix: pub_prod_ / prv_prod_ / prod_events_ / prod_integrity_
# URL: https://production.wompi.co
# Para migrar a producción, simplemente reemplaza las llaves de test por las de prod
# WOMPI_PUBLIC_KEY=pub_prod_your_wompi_public_key_here
# WOMPI_PRIVATE_KEY=prv_prod_your_wompi_private_key_here
# WOMPI_EVENTS_SECRET=prod_events_your_events_secret_here
# WOMPI_INTEGRITY_SECRET=prod_integrity_your_integrity_secret_here

# DATOS DE PRUEBA PARA SANDBOX:
# Tarjeta Aprobada: 4242 4242 4242 4242
# Tarjeta Rechazada: 4111 1111 1111 1111
# Nequi Aprobado: 3991111111
# Nequi Rechazado: 3992222222

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===========================================
# WHATSAPP BUSINESS API (Intermediario Bot)
# ===========================================
# Para configurar WhatsApp Business, sigue estos pasos:
# 1. Crea una cuenta de Meta Business: https://business.facebook.com
# 2. Configura WhatsApp en Meta Business Manager
# 3. Crea una app de Meta Developer: https://developers.facebook.com
# 4. Agrega el producto WhatsApp a tu app
# 5. Configura el webhook para recibir mensajes

# Phone Number ID (del producto WhatsApp en Meta Developer)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Access Token (Temporary Access Token del producto WhatsApp)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Webhook Verify Token (crea uno aleatorio, ej: melo-sportt-bot-2024)
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verify_token

# Tu número de teléfono (Fuyi) para recibir resúmenes
# Formato: 57 + número (sin el +)
FUYI_PHONE_NUMBER=573238020198

# Número del dueño de la tienda (para escalar conversaciones)
# Si no se configura, se usará FUYI_PHONE_NUMBER
STORE_OWNER_PHONE=573044155473

# Comisión del intermediario (porcentaje, ej: 12 = 12%)
INTERMEDIARY_COMMISSION_PERCENTAGE=12
